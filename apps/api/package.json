{
  "name": "@judo-bracket/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && esbuild src/main.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:pg --external:@prisma/client",
    "dev": "node --watch --import tsx ./src/main.ts",
    "start": "node ./dist/index.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "seed": "tsx ./prisma/seed.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@prisma/client": "^7.6.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@judo-bracket/config": "file:../../packages/config",
    "@judo-bracket/types": "file:../../packages/types",
    "@judo-bracket/utils": "file:../../packages/utils",
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "tsx": "^4.20.3"
  }
}
