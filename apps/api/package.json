{
  "name": "@judo-bracket/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npx -y node@20.19.0 ./node_modules/prisma/build/index.js generate --config ../../prisma.config.ts",
    "dev": "node --watch --import tsx ./src/main.ts",
    "start": "node --import tsx ./src/main.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "seed": "tsx ./prisma/seed.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@prisma/client": "^7.6.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@judo-bracket/config": "file:../../packages/config",
    "@judo-bracket/types": "file:../../packages/types",
    "@judo-bracket/utils": "file:../../packages/utils",
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsx": "^4.20.3"
  },
  "devDependencies": {
    "prisma": "^7.6.0"
  }
}
